[webserver]
webserver ansible_host=<webserver IP> ansible_user=ubuntu ansible_ssh_private_key_file=./ansible_test_key ansible_python_interpreter=/usr/bin/python3

[dbserver]
dbserver ansible_host=<dbserver IP> ansible_user=ubuntu ansible_ssh_private_key_file=./ansible_test_key ansible_python_interpreter=/usr/bin/python3

[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=./ansible_test_key
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
